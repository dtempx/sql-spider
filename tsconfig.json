{
  "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "removeComments": true,
      "declaration": true,
      "resolveJsonModule": true,
      "sourceMap": true,
      "strict": true,
      "skipLibCheck": true
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
